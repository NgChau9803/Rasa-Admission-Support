# 1. GEMINI API Keys (For Embeddings and LLM)
# Add up to 5 keys here for automatic rotation on 429 errors
GOOGLE_API_KEY_1=your_google_key_1_here
GOOGLE_API_KEY_2=your_google_key_2_here
GOOGLE_API_KEY_3=your_google_key_3_here
GOOGLE_API_KEY_4=your_google_key_4_here
GOOGLE_API_KEY_5=your_google_key_5_here

# Bypass Rasa 3.16.2 openai validation bug
OPENAI_API_KEY=dummy

# 2. Pinecone API Key (For Vector Database)
PINECONE_API_KEY=your_pinecone_key_here

# 3. Rasa Pro License Key (Required for Rasa CALM)
RASA_PRO_LICENSE=your_rasa_pro_license_here
